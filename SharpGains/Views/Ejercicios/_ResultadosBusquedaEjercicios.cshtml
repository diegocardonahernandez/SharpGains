@model List<SharpGains.Models.Ejercicio>
@{
    static string GetGrupoIcon(string grupo)
    {
        return grupo.ToLowerInvariant() switch
        {
            var g when g.Contains("pecho")                              => "bi-heart-pulse",
            var g when g.Contains("espalda")                            => "bi-layout-sidebar-reverse",
            var g when g.Contains("hombro") || g.Contains("deltoid")    => "bi-arrows-fullscreen",
            var g when g.Contains("b" + "ícep") || g.Contains("bicep")  => "bi-lightning-charge",
            var g when g.Contains("tr" + "ícep") || g.Contains("tricep")=> "bi-lightning-charge-fill",
            var g when g.Contains("pierna") || g.Contains("cuádr") || g.Contains("quadr") || g.Contains("femoral") => "bi-person-walking",
            var g when g.Contains("glúteo") || g.Contains("gluteo") || g.Contains("cadera") => "bi-person-standing",
            var g when g.Contains("gemelo") || g.Contains("pantorrilla") => "bi-arrow-down-square",
            var g when g.Contains("abdomen") || g.Contains("core") || g.Contains("abdom") => "bi-circle-half",
            var g when g.Contains("antebrazo")                          => "bi-wrench",
            var g when g.Contains("trapecio")                           => "bi-triangle",
            var g when g.Contains("lumbar") || g.Contains("espalda baja")=> "bi-align-bottom",
            _                                                            => "bi-activity"
        };
    }

    var index = 0;
}

@if (!Model.Any())
{
    <div class="ej-empty">
        <i class="bi bi-search ej-empty-icon"></i>
        <p class="ej-empty-title">Sin resultados</p>
        <p class="ej-empty-text">Prueba con otro nombre o borra el filtro.</p>
    </div>
}
else
{
    <div class="ej-grid">
        @foreach (var ejercicio in Model)
        {
            <div class="ej-ex-card"
                 data-grupo="@ejercicio.GrupoMuscular.ToLower()"
                 style="animation-delay: @(index * 0.03)s">
                <div class="ej-ex-icon">
                    <i class="bi @GetGrupoIcon(ejercicio.GrupoMuscular)"></i>
                </div>
                <div class="ej-ex-body">
                    <p class="ej-ex-name">@ejercicio.Nombre</p>
                    <div class="ej-ex-meta">
                        <span class="ej-ex-tag ej-ex-tag-grupo">
                            @ejercicio.GrupoMuscular
                        </span>
                        @if (!string.IsNullOrWhiteSpace(ejercicio.Equipamiento))
                        {
                            <span class="ej-ex-tag ej-ex-tag-equip">
                                <i class="bi bi-tools"></i> @ejercicio.Equipamiento
                            </span>
                        }
                    </div>
                </div>
            </div>
            index++;
        }
    </div>
}