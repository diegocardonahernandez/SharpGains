@model List<SharpGains.Models.Ejercicio>

@if (Model == null || !Model.Any())
{
    <div class="sg-grupo-section">
        <div class="sg-grupo-header">
            <div class="sg-grupo-indicator"></div>
            <h2 class="sg-grupo-title">Sin resultados</h2>
            <span class="sg-badge">0 ejercicios</span>
        </div>
        <p>No se encontraron ejercicios para la búsqueda.</p>
    </div>
}
else
{
    @foreach (var grupo in Model.GroupBy(e => e.GrupoMuscular).OrderBy(g => g.Key))
    {
        <div class="sg-grupo-section" data-grupo="@grupo.Key">
            <div class="sg-grupo-header">
                <div class="sg-grupo-indicator"></div>
                <h2 class="sg-grupo-title">@grupo.Key</h2>
                <span class="sg-badge">@grupo.Count() ejercicios</span>
            </div>

            <div class="sg-ejercicios-grid">
                @foreach (var ejercicio in grupo.OrderBy(e => e.Nombre))
                {
                    <div class="sg-ejercicio-card" data-nombre="@ejercicio.Nombre.ToLower()">
                        <div class="sg-ejercicio-icon">🏋️</div>
                        <div class="sg-ejercicio-info">
                            <h3 class="sg-ejercicio-nombre">@ejercicio.Nombre</h3>
                            <div class="sg-ejercicio-meta">
                                <span class="sg-ejercicio-grupo">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="10" />
                                        <line x1="12" y1="8" x2="12" y2="16" />
                                        <line x1="8" y1="12" x2="16" y2="12" />
                                    </svg>
                                    @ejercicio.GrupoMuscular
                                </span>

                                @if (!string.IsNullOrEmpty(ejercicio.Equipamiento))
                                {
                                    <span class="sg-ejercicio-equip">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="2" y="7" width="20" height="10" rx="2" />
                                            <line x1="12" y1="7" x2="12" y2="17" />
                                        </svg>
                                        @ejercicio.Equipamiento
                                    </span>
                                }
                                else
                                {
                                    <span class="sg-ejercicio-equip sg-ejercicio-bodyweight">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                            <circle cx="12" cy="7" r="4" />
                                        </svg>
                                        Peso corporal
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="sg-ejercicio-arrow">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 15 12 9 6" />
                            </svg>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}