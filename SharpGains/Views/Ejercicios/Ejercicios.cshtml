@model List<SharpGains.Models.Ejercicio>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Ejercicios — SharpGains";

    static string GetGrupoIcon(string grupo)
    {
        return grupo.ToLowerInvariant() switch
        {
            var g when g.Contains("pecho")                              => "bi-heart-pulse",
            var g when g.Contains("espalda")                            => "bi-layout-sidebar-reverse",
            var g when g.Contains("hombro") || g.Contains("deltoid")    => "bi-arrows-fullscreen",
            var g when g.Contains("b" + "ícep") || g.Contains("bicep") => "bi-lightning-charge",
            var g when g.Contains("tr" + "ícep") || g.Contains("tricep") => "bi-lightning-charge-fill",
            var g when g.Contains("pierna") || g.Contains("cuádr") || g.Contains("quadr") || g.Contains("femoral") => "bi-person-walking",
            var g when g.Contains("glúteo") || g.Contains("gluteo") || g.Contains("cadera") => "bi-person-standing",
            var g when g.Contains("gemelo") || g.Contains("pantorrilla") => "bi-arrow-down-square",
            var g when g.Contains("abdomen") || g.Contains("core") || g.Contains("abdom") => "bi-circle-half",
            var g when g.Contains("antebrazo")                          => "bi-wrench",
            var g when g.Contains("trapecio")                           => "bi-triangle",
            var g when g.Contains("lumbar") || g.Contains("espalda baja") => "bi-align-bottom",
            _                                                            => "bi-activity"
        };
    }

    var grupos = Model
        .GroupBy(e => e.GrupoMuscular)
        .OrderBy(g => g.Key)
        .ToList();

    var totalEjercicios = Model.Count;
    var totalGrupos = grupos.Count;
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Oswald:wght@400;500;700&display=swap"
          rel="stylesheet" />
    <link rel="stylesheet" href="~/css/ejercicios.css" asp-append-version="true" />
}

<body class="ej-body">

    <!-- ============================== -->
    <!-- MAIN CONTENT -->
    <!-- ============================== -->
    <main class="ej-page">
        <div class="ej-container">

            <!-- ── Page header ── -->
            <div class="ej-page-header">
                <div class="ej-page-header-left">
                    <div class="ej-eyebrow">
                        <span class="ej-eyebrow-line"></span>
                        <span class="ej-eyebrow-text">Biblioteca</span>
                    </div>
                    <h1 class="ej-page-title">Ejercicios</h1>
                    <p class="ej-page-subtitle">
                        Explora el catálogo completo. Filtra por nombre o grupo muscular
                        y encuentra exactamente lo que necesitas para tu entreno.
                    </p>
                </div>
                <div class="ej-page-stats">
                    <div class="ej-stat">
                        <span class="ej-stat-value">@totalEjercicios</span>
                        <span class="ej-stat-label">Ejercicios</span>
                    </div>
                    <div class="ej-stat-divider"></div>
                    <div class="ej-stat">
                        <span class="ej-stat-value">@totalGrupos</span>
                        <span class="ej-stat-label">Grupos</span>
                    </div>
                </div>
            </div>

            <!-- ── Search bar ── -->
            <div class="ej-search-wrap">
                <div class="ej-search-inner">
                    <i class="bi bi-search ej-search-icon"></i>
                    <input class="ej-search-input"
                           type="search"
                           id="busqueda"
                           name="busqueda"
                           placeholder="Buscar ejercicio por nombre..."
                           autocomplete="off"
                           hx-get="/Ejercicios/Buscar"
                           hx-trigger="keyup changed delay:300ms, search"
                           hx-target="#ej-results"
                           hx-include="#busqueda"
                           hx-indicator="#ej-spinner" />
                    <span class="ej-search-spinner" id="ej-spinner">
                        <i class="bi bi-arrow-repeat"></i>
                    </span>
                </div>
            </div>

            <!-- ── Muscle group filter chips ── -->
            <div class="ej-chips" id="ej-chips">
                <button class="ej-chip ej-chip-active" data-grupo="all">
                    <i class="bi bi-grid-3x3-gap"></i> Todos
                </button>
                @foreach (var grupo in grupos)
                {
                    <button class="ej-chip" data-grupo="@grupo.Key.ToLower()">
                        <i class="bi @GetGrupoIcon(grupo.Key)"></i>
                        @grupo.Key
                        <span class="ej-chip-count">@grupo.Count()</span>
                    </button>
                }
            </div>

            <!-- ── Results container ── -->
            <div id="ej-results" class="ej-results">
                @await Html.PartialAsync("_ResultadosBusquedaEjercicios", Model)
            </div>

        </div>
    </main>

    <!-- ============================== -->
    <!-- FOOTER -->
    <!-- ============================== -->
    <footer class="ej-footer">
        <div class="ej-container ej-footer-inner">
            <div class="ej-footer-left">
                <a class="ej-logo" asp-controller="Home" asp-action="Index">
                    SHARP<span class="ej-logo-accent">GAINS</span>
                </a>
                <p class="ej-footer-tagline">Tu entrenamiento. Tus datos. Tu progreso.</p>
            </div>
            <div class="ej-footer-right">
                <a class="ej-footer-link" asp-controller="Home" asp-action="Index">Inicio</a>
                <a class="ej-footer-link" asp-controller="Home" asp-action="Privacy">Privacidad</a>
            </div>
        </div>
        <div class="ej-container">
            <div class="ej-footer-bottom">
                <p>&copy; 2026 SharpGains</p>
            </div>
        </div>
    </footer>

</body>

@section Scripts {
    <script>
        (function () {
            // ── Chip filter ──
            const chips = document.querySelectorAll('.ej-chip');
            const resultsContainer = document.getElementById('ej-results');

            function filterCards(grupo) {
                const cards = resultsContainer.querySelectorAll('.ej-ex-card');
                cards.forEach(card => {
                    if (grupo === 'all' || card.dataset.grupo === grupo) {
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });
            }

            chips.forEach(chip => {
                chip.addEventListener('click', () => {
                    chips.forEach(c => c.classList.remove('ej-chip-active'));
                    chip.classList.add('ej-chip-active');
                    filterCards(chip.dataset.grupo);
                });
            });

            document.body.addEventListener('htmx:afterSwap', (e) => {
                if (e.detail.target.id === 'ej-results') {
                    const activeChip = document.querySelector('.ej-chip-active');
                    if (activeChip && activeChip.dataset.grupo !== 'all') {
                        filterCards(activeChip.dataset.grupo);
                    }
                }
            });

            document.getElementById('busqueda')?.addEventListener('input', () => {
                chips.forEach(c => c.classList.remove('ej-chip-active'));
                document.querySelector('[data-grupo="all"]')?.classList.add('ej-chip-active');
            });
        })();
    </script>
}