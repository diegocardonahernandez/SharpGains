@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión — SharpGains</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Oswald:wght@400;500;700&display=swap"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body class="login-body">

    <div class="login-wrapper">

        <div class="login-card">

            <!-- Header -->
            <div class="login-header">
                <h1 class="login-title">Bienvenido de vuelta</h1>
                <p class="login-subtitle">Inicia sesión en SharpGains para seguir progresando.</p>
            </div>

            <!-- Error -->
            @if (ViewBag.ERROR != null)
            {
                <div class="login-alert">
                    <i class="bi bi-exclamation-circle"></i>
                    <span>@ViewBag.ERROR</span>
                </div>
            }

            <!-- Form -->
            <form method="post" asp-controller="Usuarios" asp-action="Login" class="login-form">
                <div class="login-field">
                    <label class="login-label" for="correo">Correo electrónico</label>
                    <div class="login-input-wrap">
                        <input class="login-input"
                               type="email"
                               id="correo"
                               name="correo"
                               placeholder="tu@email.com"
                               autocomplete="email"
                               required />
                    </div>
                </div>

                <div class="login-field">
                    <label class="login-label" for="contrasena">Contraseña</label>
                    <div class="login-input-wrap">
                        <input class="login-input login-input-pw"
                               type="password"
                               id="contrasena"
                               name="contrasena"
                               placeholder="••••••••"
                               autocomplete="current-password"
                               required />
                        <button type="button"
                                class="login-toggle-pw"
                                aria-label="Mostrar contraseña">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="login-btn-submit">
                    Iniciar sesión
                </button>
            </form>

            <!-- Motivational nudge -->
            <div class="login-nudge">
                <i class="bi bi-lightning-charge-fill login-nudge-icon"></i>
                <p class="login-nudge-text">
                    Tu siguiente PR no se va a batir solo.
                    <span class="login-nudge-highlight">Entra y dale caña.</span>
                </p>
            </div>

            <!-- Footer -->
            <div class="login-card-footer">
                <p class="login-footer-text">
                    ¿Primera vez aquí? &nbsp;·&nbsp;
                    <a class="login-link" asp-controller="Usuarios" asp-action="Registro">Crear cuenta</a>
                </p>
            </div>
        </div>

        <!-- Back link (outside card) -->
        <a class="login-back" asp-controller="Home" asp-action="Index">
            <i class="bi bi-arrow-left"></i> Volver al inicio
        </a>
    </div>

    <script>
        (function () {
            const btn = document.querySelector('.login-toggle-pw');
            const input = document.getElementById('contrasena');
            if (btn && input) {
                btn.addEventListener('click', () => {
                    const isHidden = input.type === 'password';
                    input.type = isHidden ? 'text' : 'password';
                    btn.querySelector('i').className =
                        isHidden ? 'bi bi-eye-slash' : 'bi bi-eye';
                });
            }
        })();
    </script>
</body>
</html>