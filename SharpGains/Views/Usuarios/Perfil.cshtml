@model SharpGains.Models.Usuario
@{
    Layout = "_Layout";
    ViewData["Title"] = "Mi Perfil — SharpGains";

    string nombreCompleto = $"{Model.Nombre} {Model.Apellidos}".Trim();
    string iniciales = "";
    if (!string.IsNullOrEmpty(Model.Nombre))
        iniciales += Model.Nombre[0];
    if (!string.IsNullOrEmpty(Model.Apellidos))
        iniciales += Model.Apellidos[0];
    iniciales = iniciales.ToUpperInvariant();

    int totalRutinas = ViewBag.TotalRutinas;
    int totalSesiones = ViewBag.TotalSesiones;
    int totalSeries = ViewBag.TotalSeries;
    decimal volumenTotal = ViewBag.VolumenTotal;

    string FormatVolumen(decimal vol)
    {
        if (vol >= 1_000_000) return $"{(vol / 1_000_000):0.#}M";
        if (vol >= 1_000) return $"{(vol / 1_000):0.#}K";
        return vol.ToString("0");
    }
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Oswald:wght@400;500;700&display=swap"
          rel="stylesheet" />
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/rutinas.css" asp-append-version="true" />
}

<body class="pf-body">

    <!-- ============================== -->
    <!-- MAIN CONTENT -->
    <!-- ============================== -->
    <main class="pf-main">
        <div class="pf-container">

            <!-- ── Profile header ── -->
            <section class="pf-header">
                <div class="pf-avatar">
                    <span class="pf-avatar-text">@iniciales</span>
                </div>
                <div class="pf-header-info">
                    <div class="pf-eyebrow">
                        <span class="pf-eyebrow-line"></span>
                        <span class="pf-eyebrow-text">Mi perfil</span>
                    </div>
                    <h1 class="pf-name">@nombreCompleto</h1>
                    <p class="pf-email">
                        <i class="bi bi-envelope"></i> @Model.Correo
                    </p>
                </div>
            </section>

            <!-- ── Stats grid ── -->
            <section class="pf-stats">
                <div class="pf-stat-card">
                    <div class="pf-stat-icon"><i class="bi bi-journal-text"></i></div>
                    <div class="pf-stat-data">
                        <span class="pf-stat-value">@totalRutinas</span>
                        <span class="pf-stat-label">Rutinas</span>
                    </div>
                </div>
                <div class="pf-stat-card">
                    <div class="pf-stat-icon"><i class="bi bi-calendar-check"></i></div>
                    <div class="pf-stat-data">
                        <span class="pf-stat-value">@totalSesiones</span>
                        <span class="pf-stat-label">Sesiones</span>
                    </div>
                </div>
                <div class="pf-stat-card">
                    <div class="pf-stat-icon"><i class="bi bi-layers"></i></div>
                    <div class="pf-stat-data">
                        <span class="pf-stat-value">@totalSeries</span>
                        <span class="pf-stat-label">Series</span>
                    </div>
                </div>
                <div class="pf-stat-card pf-stat-card-accent">
                    <div class="pf-stat-icon"><i class="bi bi-fire"></i></div>
                    <div class="pf-stat-data">
                        <span class="pf-stat-value">@FormatVolumen(volumenTotal)</span>
                        <span class="pf-stat-label">Kg movidos</span>
                    </div>
                </div>
            </section>

            <!-- ── Info cards ── -->
            <div class="pf-cards">

                <!-- Body metrics -->
                <section class="pf-card">
                    <div class="pf-card-header">
                        <h2 class="pf-card-title">
                            <i class="bi bi-person-bounding-box"></i> Métricas corporales
                        </h2>
                    </div>
                    <div class="pf-card-body">
                        <div class="pf-detail-grid">
                            <div class="pf-detail">
                                <span class="pf-detail-label">Altura</span>
                                <span class="pf-detail-value">
                                    @if (Model.Altura.HasValue)
                                    {
                                        @($"{Model.Altura:0.##} cm")
                                    }
                                    else
                                    {
                                        <span class="pf-detail-empty">Sin registrar</span>
                                    }
                                </span>
                            </div>
                            <div class="pf-detail">
                                <span class="pf-detail-label">Peso</span>
                                <span class="pf-detail-value">
                                    @if (Model.Peso.HasValue)
                                    {
                                        @($"{Model.Peso:0.##} kg")
                                    }
                                    else
                                    {
                                        <span class="pf-detail-empty">Sin registrar</span>
                                    }
                                </span>
                            </div>
                            @if (Model.Altura.HasValue && Model.Peso.HasValue && Model.Altura > 0)
                            {
                                var alturaM = (decimal)Model.Altura / 100m;
                                var imc = (decimal)Model.Peso / (alturaM * alturaM);
                                <div class="pf-detail">
                                    <span class="pf-detail-label">IMC</span>
                                    <span class="pf-detail-value">@imc.ToString("0.0")</span>
                                </div>
                            }
                        </div>
                    </div>
                    <i class="bi bi-heart-pulse pf-card-bg-icon"></i>
                </section>

                <!-- Account info -->
                <section class="pf-card">
                    <div class="pf-card-header">
                        <h2 class="pf-card-title">
                            <i class="bi bi-shield-check"></i> Cuenta
                        </h2>
                    </div>
                    <div class="pf-card-body">
                        <div class="pf-detail-grid">
                            <div class="pf-detail">
                                <span class="pf-detail-label">Nombre</span>
                                <span class="pf-detail-value">@Model.Nombre</span>
                            </div>
                            <div class="pf-detail">
                                <span class="pf-detail-label">Apellidos</span>
                                <span class="pf-detail-value">@(Model.Apellidos ?? "—")</span>
                            </div>
                            <div class="pf-detail pf-detail-full">
                                <span class="pf-detail-label">Correo</span>
                                <span class="pf-detail-value">@Model.Correo</span>
                            </div>
                        </div>
                    </div>
                    <i class="bi bi-person-gear pf-card-bg-icon"></i>
                </section>

            </div>

            <!-- ── Quick actions ── -->
            <section class="pf-actions">
                <a class="pf-action-btn pf-action-btn-primary"
                   asp-controller="Rutinas" asp-action="CrearRutina">
                    <i class="bi bi-plus-lg"></i> Crear rutina
                </a>
                <a class="pf-action-btn pf-action-btn-secondary"
                   asp-controller="Ejercicios" asp-action="Ejercicios">
                    <i class="bi bi-search"></i> Explorar ejercicios
                </a>
                <a class="pf-action-btn pf-action-btn-danger"
                   asp-controller="Usuarios" asp-action="CerrarSesion">
                    <i class="bi bi-box-arrow-right"></i> Cerrar sesión
                </a>
            </section>

            <!-- ============================== -->
            <!-- DYNAMIC CONTENT PANEL          -->
            <!-- ============================== -->
            <section class="pf-content-section">

                <!-- ── Chip selector bar ── -->
                <div class="pf-chip-bar">
                    <button class="pf-chip"
                            id="pf-chip-rutinas"
                            data-url="@Url.Action("RutinasUsuario", "Usuarios")"
                            onclick="toggleContentPanel(this)">
                        <i class="bi bi-journal-text"></i>
                        <span>Mis Rutinas</span>
                        <span class="pf-chip-count">@totalRutinas</span>
                    </button>
                    @* Futuras chips: Sesiones, Progreso, etc. *@
                </div>

                <!-- ── Loading spinner ── -->
                <div class="pf-content-spinner" id="pf-content-spinner">
                    <i class="bi bi-arrow-repeat"></i>
                    <span>Cargando…</span>
                </div>

                <!-- ── Injection target ── -->
                <div id="pf-content-panel"></div>

            </section>

        </div>
    </main>

    <!-- ============================== -->
    <!-- FOOTER -->
    <!-- ============================== -->
    <footer class="pf-footer">
        <div class="pf-container pf-footer-inner">
            <div class="pf-footer-left">
                <a class="pf-logo" asp-controller="Home" asp-action="Index">
                    SHARP<span class="pf-logo-accent">GAINS</span>
                </a>
                <p class="pf-footer-tagline">Tu entrenamiento. Tus datos. Tu progreso.</p>
            </div>
            <div class="pf-footer-right">
                <a class="pf-footer-link" asp-controller="Home" asp-action="Index">Inicio</a>
                <a class="pf-footer-link" asp-controller="Ejercicios" asp-action="Ejercicios">Ejercicios</a>
                <a class="pf-footer-link" asp-controller="Home" asp-action="Privacy">Privacidad</a>
            </div>
        </div>
        <div class="pf-container">
            <div class="pf-footer-bottom">
                <p>&copy; 2026 SharpGains</p>
            </div>
        </div>
    </footer>

</body>

@section Scripts {
    <script>
        function toggleContentPanel(chip) {
            const panel = document.getElementById('pf-content-panel');
            const spinner = document.getElementById('pf-content-spinner');
            const allChips = document.querySelectorAll('.pf-chip');
            const isActive = chip.classList.contains('pf-chip-active');

            // Si ya está activo → cerrar el panel
            if (isActive) {
                chip.classList.remove('pf-chip-active');
                panel.innerHTML = '';
                return;
            }

            // Desactivar todos los chips y activar el seleccionado
            allChips.forEach(c => c.classList.remove('pf-chip-active'));
            chip.classList.add('pf-chip-active');

            // Mostrar spinner, ocultar contenido anterior
            spinner.style.display = 'flex';
            panel.innerHTML = '';

            // Petición HTMX manual via fetch (más control que hx-get para toggle)
            const url = chip.getAttribute('data-url');
            fetch(url)
                .then(response => response.text())
                .then(html => {
                    spinner.style.display = 'none';
                    panel.innerHTML = html;
                })
                .catch(() => {
                    spinner.style.display = 'none';
                    panel.innerHTML = '<p style="text-align:center;color:var(--pf-text-3);padding:24px;">Error al cargar el contenido.</p>';
                });
        }
    </script>
}