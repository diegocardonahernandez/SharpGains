@model SharpGains.Models.Usuario

@{
    ViewData["Title"] = "Mi Perfil";

    decimal? imc = null;
    string imcLabel = "—";
    if (Model.Altura != null && Model.Peso != null && Model.Altura > 0)
    {
        var alturaM = Model.Altura / 100m;
        imc = Model.Peso / (alturaM * alturaM);
        imcLabel = imc?.ToString("0.0") ?? "—";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/Usuarios/Perfil.css" asp-append-version="true" />
}

<div class="container py-4">

    <!-- Header del Perfil -->
    <div class="sg-profile-header">
        <div class="sg-profile-avatar">
            @Model.Nombre?.Substring(0, 1).ToUpper()
        </div>
        <div>
            <p class="sg-profile-name">@Model.Nombre @Model.Apellidos</p>
            <p class="sg-profile-email">@Model.Correo</p>
        </div>
    </div>

    <!-- Grid de Estadísticas Rápidas (4 columnas) -->
    <div class="sg-stats-grid">
        <div class="sg-stat-card">
            <span class="sg-stat-card__label">Peso</span>
            <span class="sg-stat-card__value sg-stat-card__value--accent">
                @(Model.Peso?.ToString("0.0") ?? "—")<span class="sg-stat-card__unit"> kg</span>
            </span>
        </div>
        <div class="sg-stat-card">
            <span class="sg-stat-card__label">IMC</span>
            <span class="sg-stat-card__value sg-stat-card__value--accent">
                @imcLabel<span class="sg-stat-card__unit"> kg/m²</span>
            </span>
        </div>
        <div class="sg-stat-card">
            <span class="sg-stat-card__label">Racha</span>
            <span class="sg-stat-card__value">
                0<span class="sg-stat-card__unit"> días</span>
            </span>
        </div>
        <div class="sg-stat-card">
            <span class="sg-stat-card__label">Total kg</span>
            <span class="sg-stat-card__value">
                0<span class="sg-stat-card__unit"> kg</span>
            </span>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <!-- Panel: Información Personal -->
            <div class="sg-panel">
                <div class="sg-panel__header">
                    <h4 class="sg-panel__title">Información Personal</h4>
                    <button class="btn-sg btn-sg-ghost btn-sg-sm" type="button">Editar</button>
                </div>
                <div class="sg-info-row">
                    <div class="sg-info-item">
                        <p class="sg-info-item__label">Nombre</p>
                        <p class="sg-info-item__value">@Model.Nombre</p>
                    </div>
                    <div class="sg-info-item">
                        <p class="sg-info-item__label">Apellidos</p>
                        <p class="sg-info-item__value">@(Model.Apellidos ?? "—")</p>
                    </div>
                    <div class="sg-info-item sg-info-item--full">
                        <p class="sg-info-item__label">Correo Electrónico</p>
                        <p class="sg-info-item__value">@Model.Correo</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <!-- Panel: Datos Físicos -->
            <div class="sg-panel">
                <div class="sg-panel__header">
                    <h4 class="sg-panel__title">Datos Físicos</h4>
                    <button class="btn-sg btn-sg-ghost btn-sg-sm" type="button">Actualizar</button>
                </div>
                <div class="sg-info-row">
                    <div class="sg-info-item">
                        <p class="sg-info-item__label">Altura</p>
                        <p class="sg-info-item__value">
                            @(Model.Altura?.ToString("0.0") ?? "—")
                            @if (Model.Altura != null) { <span class="sg-stat-card__unit">cm</span> }
                        </p>
                    </div>
                    <div class="sg-info-item">
                        <p class="sg-info-item__label">Peso</p>
                        <p class="sg-info-item__value">
                            @(Model.Peso?.ToString("0.0") ?? "—")
                            @if (Model.Peso != null) { <span class="sg-stat-card__unit">kg</span> }
                        </p>
                    </div>
                    <div class="sg-info-item">
                        <p class="sg-info-item__label">IMC</p>
                        <p class="sg-info-item__value">@imcLabel <span class="sg-stat-card__unit">kg/m²</span></p>
                    </div>
                    <div class="sg-info-item">
                        <p class="sg-info-item__label">Sesiones</p>
                        <p class="sg-info-item__value">@Model.Sesions.Count</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel: Gráfico de Progreso (placeholder) -->
        <div class="col-12">
            <div class="sg-panel">
                <div class="sg-panel__header">
                    <h4 class="sg-panel__title">Progreso</h4>
                    <span class="sg-badge sg-badge-neutral">Próximamente</span>
                </div>
                <div class="sg-chart-placeholder">
                    <span class="sg-chart-placeholder__icon">📊</span>
                    <p class="sg-chart-placeholder__text">El gráfico de progreso estará disponible pronto</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Acciones -->
    <div class="sg-profile-actions">
        <a asp-action="Index" asp-controller="Home" class="btn-sg btn-sg-ghost">
            Inicio
        </a>
        <a asp-action="CerrarSesion" asp-controller="Usuarios" class="btn-sg btn-sg-danger">
            Cerrar Sesión
        </a>
    </div>

</div>