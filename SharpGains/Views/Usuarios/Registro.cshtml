@model SharpGains.Models.Usuario
@{
    ViewData["Title"] = "Crear Cuenta";
    Layout = "_AuthLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
}

<body class="reg-body">

    <div class="reg-wrapper">

        <div class="reg-card">

            <!-- Header -->
            <div class="reg-header">
                <h1 class="reg-title">Crea tu cuenta</h1>
                <p class="reg-subtitle">
                    Empieza a entrenar con datos. Es gratis, rápido y sin compromisos.
                </p>
            </div>

            <!-- Motivational banner -->
            <div class="reg-banner">
                <i class="bi bi-trophy-fill reg-banner-icon"></i>
                <p class="reg-banner-text">
                    <strong>Tu primer paso hacia tu mejor versión.</strong>
                    Rutinas, sets y estadísticas — todo lo que necesitas.
                </p>
            </div>

            <!-- Alerts -->
            @if (ViewBag.ERROR != null)
            {
                <div class="reg-alert reg-alert-error">
                    <i class="bi bi-exclamation-circle"></i>
                    <span>@ViewBag.ERROR</span>
                </div>
            }

            @if (ViewBag.MENSAJE != null)
            {
                <div class="reg-alert reg-alert-success">
                    <i class="bi bi-check-circle"></i>
                    <span>@ViewBag.MENSAJE</span>
                    <a class="reg-alert-link" asp-controller="Usuarios" asp-action="Login">
                        Iniciar sesión <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            }

            <!-- Form -->
            <form method="post" asp-controller="Usuarios" asp-action="Registro" class="reg-form">

                <!-- Row: Nombre + Apellidos -->
                <div class="reg-row">
                    <div class="reg-field">
                        <label class="reg-label" for="Nombre">Nombre</label>
                        <input class="reg-input"
                               type="text"
                               id="Nombre"
                               name="Nombre"
                               placeholder="Tu nombre"
                               value="@Model?.Nombre"
                               autocomplete="given-name"
                               required />
                    </div>
                    <div class="reg-field">
                        <label class="reg-label" for="Apellidos">Apellidos</label>
                        <input class="reg-input"
                               type="text"
                               id="Apellidos"
                               name="Apellidos"
                               placeholder="Tus apellidos"
                               value="@Model?.Apellidos"
                               autocomplete="family-name"
                               required />
                    </div>
                </div>

                <!-- Row: Correo + Contraseña -->
                <div class="reg-row">
                    <div class="reg-field">
                        <label class="reg-label" for="Correo">Correo electrónico</label>
                        <input class="reg-input"
                               type="email"
                               id="Correo"
                               name="Correo"
                               placeholder="tu@email.com"
                               value="@Model?.Correo"
                               autocomplete="email"
                               hx-get="/Usuarios/ValidarCorreo"
                               hx-trigger="keyup changed delay:400ms"
                               hx-target="#correo-feedback"
                               hx-params="correo"
                               hx-vals='{"correo": ""}'
                               hx-include="#Correo"
                               required />
                        <div id="correo-feedback" class="reg-feedback"></div>
                    </div>
                    <div class="reg-field">
                        <label class="reg-label" for="Contrasena">Contraseña</label>
                        <div class="reg-input-wrap">
                            <input class="reg-input reg-input-pw"
                                   type="password"
                                   id="Contrasena"
                                   name="Contrasena"
                                   placeholder="Mínimo 6 caracteres"
                                   autocomplete="new-password"
                                   minlength="6"
                                   required />
                            <button type="button"
                                    class="reg-toggle-pw"
                                    aria-label="Mostrar contraseña">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Row: Altura + Peso -->
                <div class="reg-row">
                    <div class="reg-field">
                        <label class="reg-label" for="Altura">Altura (cm)</label>
                        <input class="reg-input"
                               type="number"
                               id="Altura"
                               name="Altura"
                               placeholder="175"
                               value="@Model?.Altura"
                               step="0.01"
                               min="100"
                               max="250"
                               autocomplete="off"
                               required />
                    </div>
                    <div class="reg-field">
                        <label class="reg-label" for="Peso">Peso (kg)</label>
                        <input class="reg-input"
                               type="number"
                               id="Peso"
                               name="Peso"
                               placeholder="75"
                               value="@Model?.Peso"
                               step="0.01"
                               min="30"
                               max="300"
                               autocomplete="off"
                               required />
                    </div>
                </div>

                <button type="submit" class="reg-btn-submit">
                    Crear cuenta
                </button>
            </form>

            <!-- Footer -->
            <div class="reg-card-footer">
                <p class="reg-footer-text">
                    ¿Ya tienes cuenta? &nbsp;·&nbsp;
                    <a class="reg-link" asp-controller="Usuarios" asp-action="Login">Iniciar sesión</a>
                </p>
            </div>
        </div>

        <!-- Back link -->
        <a class="reg-back" asp-controller="Home" asp-action="Index">
            <i class="bi bi-arrow-left"></i> Volver al inicio
        </a>
    </div>

</body>

@section Scripts {
    <script>
        (function () {
            const correoInput = document.getElementById('Correo');
            if (correoInput) {
                correoInput.addEventListener('htmx:configRequest', (e) => {
                    e.detail.parameters['correo'] = correoInput.value;
                });
            }

            const btn = document.querySelector('.reg-toggle-pw');
            const input = document.getElementById('Contrasena');
            if (btn && input) {
                btn.addEventListener('click', () => {
                    const isHidden = input.type === 'password';
                    input.type = isHidden ? 'text' : 'password';
                    btn.querySelector('i').className =
                        isHidden ? 'bi bi-eye-slash' : 'bi bi-eye';
                });
            }
        })();
    </script>
}