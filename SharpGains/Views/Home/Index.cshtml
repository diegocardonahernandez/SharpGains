@{
    Layout = null;
    bool isLogged = Context.Session.GetString("IDUSUARIOLOGEADO") != null;
    SharpGains.Models.Usuario usuario = ViewBag.USUARIO;
    string nombreUsuario = usuario?.Nombre ?? "";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SharpGains — Tu entrenamiento, tu progreso</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Oswald:wght@400;500;600;700&display=swap"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
</head>
<body class="landing-body">

    <!-- ============================== -->
    <!-- NAV -->
    <!-- ============================== -->
    <nav class="l-nav">
        <div class="l-container l-nav-inner">
            <a class="l-logo" asp-controller="Home" asp-action="Index">
                SHARP<span class="l-logo-accent">GAINS</span>
            </a>
            <div class="l-nav-links">
                <a class="l-nav-link" asp-controller="Ejercicios" asp-action="Ejercicios">Ejercicios</a>
                @if (isLogged)
                {
                    <a class="l-nav-link" asp-controller="Rutinas" asp-action="CrearRutina">Mis Rutinas</a>
                    <a class="l-nav-link" asp-controller="Usuarios" asp-action="Perfil">
                        <i class="bi bi-person-circle"></i> @nombreUsuario
                    </a>
                    <a class="l-btn l-btn-outline l-btn-sm"
                       asp-controller="Usuarios" asp-action="CerrarSesion">Salir</a>
                }
                else
                {
                    <a class="l-nav-link" asp-controller="Usuarios" asp-action="Login">Iniciar Sesión</a>
                    <a class="l-btn l-btn-accent l-btn-sm"
                       asp-controller="Usuarios" asp-action="Registro">Crear Cuenta</a>
                }
            </div>
            <button class="l-nav-toggle" aria-label="Abrir menú" id="navToggle">
                <i class="bi bi-list"></i>
            </button>
        </div>
    </nav>

    <!-- Mobile menu -->
    <div class="l-mobile-menu" id="mobileMenu">
        <div class="l-mobile-inner">
            <button class="l-mobile-close" id="mobileClose" aria-label="Cerrar menú">
                <i class="bi bi-x-lg"></i>
            </button>
            <a class="l-mobile-link" asp-controller="Ejercicios" asp-action="Ejercicios">Ejercicios</a>
            @if (isLogged)
            {
                <a class="l-mobile-link" asp-controller="Rutinas" asp-action="CrearRutina">Mis Rutinas</a>
                <a class="l-mobile-link" asp-controller="Usuarios" asp-action="Perfil">Mi Perfil</a>
                <a class="l-btn l-btn-outline l-btn-block"
                   asp-controller="Usuarios" asp-action="CerrarSesion">Cerrar Sesión</a>
            }
            else
            {
                <a class="l-mobile-link" asp-controller="Usuarios" asp-action="Login">Iniciar Sesión</a>
                <a class="l-btn l-btn-accent l-btn-block"
                   asp-controller="Usuarios" asp-action="Registro">Crear Cuenta</a>
            }
        </div>
    </div>

    <!-- ============================== -->
    <!-- HERO -->
    <!-- ============================== -->
    <section class="l-hero">
        <div class="l-container">
            @if (isLogged)
            {
                <p class="l-hero-eyebrow">Bienvenido de vuelta</p>
                <h1 class="l-hero-title">
                    Qué pasa,<br />
                    <span class="l-hero-accent">@nombreUsuario</span>.
                </h1>
                <p class="l-hero-sub">
                    Tu constancia habla por ti. Revisa tus rutinas,
                    registra tu sesión y sigue rompiendo límites. 💪
                </p>
                <div class="l-hero-actions">
                    <a class="l-btn l-btn-accent l-btn-lg"
                       asp-controller="Rutinas" asp-action="CrearRutina">
                        Ir a mis rutinas <i class="bi bi-arrow-right"></i>
                    </a>
                    <a class="l-btn l-btn-ghost l-btn-lg"
                       asp-controller="Ejercicios" asp-action="Ejercicios">
                        Explorar ejercicios
                    </a>
                </div>
            }
            else
            {
                <p class="l-hero-eyebrow">Tu entreno, tus reglas</p>
                <h1 class="l-hero-title">
                    Entrena.<br />
                    Registra.<br />
                    <span class="l-hero-accent">Progresa</span>.
                </h1>
                <p class="l-hero-sub">
                    Rutinas personalizadas, registro de cada serie
                    y estadísticas de progreso. Sin excusas.
                </p>
                <div class="l-hero-actions">
                    <a class="l-btn l-btn-accent l-btn-lg"
                       asp-controller="Usuarios" asp-action="Registro">
                        Empezar gratis <i class="bi bi-arrow-right"></i>
                    </a>
                    <a class="l-btn l-btn-ghost l-btn-lg"
                       asp-controller="Usuarios" asp-action="Login">
                        Ya tengo cuenta
                    </a>
                </div>
            }

            <!-- Scrolling marquee -->
            <div class="l-marquee" aria-hidden="true">
                <div class="l-marquee-track">
                    <span>SHARPGAINS</span><span>·</span>
                    <span>ENTRENA CON PROPÓSITO</span><span>·</span>
                    <span>100% GRATIS</span><span>·</span>
                    <span>RUTINAS</span><span>·</span>
                    <span>PROGRESO</span><span>·</span>
                    <span>ESTADÍSTICAS</span><span>·</span>
                    <span>SHARPGAINS</span><span>·</span>
                    <span>ENTRENA CON PROPÓSITO</span><span>·</span>
                    <span>100% GRATIS</span><span>·</span>
                    <span>RUTINAS</span><span>·</span>
                    <span>PROGRESO</span><span>·</span>
                    <span>ESTADÍSTICAS</span><span>·</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================== -->
    <!-- BENTO GRID -->
    <!-- ============================== -->
    <section class="l-bento">
        <div class="l-container">
            <!-- Row 1 -->
            <div class="l-bento-grid">
                <!-- Feature big -->
                <div class="l-bento-card l-bento-wide">
                    <div class="l-bento-card-head">
                        <span class="l-bento-icon"><i class="bi bi-journal-plus"></i></span>
                        <span class="l-bento-tag">Rutinas</span>
                    </div>
                    <h3 class="l-bento-title">Crea rutinas a tu medida</h3>
                    <p class="l-bento-text">
                        Push, pull, legs o lo que te mole. Elige ejercicios,
                        define series y monta planes que de verdad te funcionen.
                    </p>
                </div>

                <!-- Stat card -->
                <div class="l-bento-card l-bento-stat-card">
                    <span class="l-bento-stat-number">∞</span>
                    <span class="l-bento-stat-label">Rutinas ilimitadas</span>
                </div>

                <!-- Feature -->
                <div class="l-bento-card">
                    <div class="l-bento-card-head">
                        <span class="l-bento-icon"><i class="bi bi-pencil-square"></i></span>
                        <span class="l-bento-tag">Registro</span>
                    </div>
                    <h3 class="l-bento-title">Registra al vuelo</h3>
                    <p class="l-bento-text">
                        Peso, reps, sensaciones. En segundos.
                        Sin complicaciones, directo al grano.
                    </p>
                </div>

                <!-- Feature -->
                <div class="l-bento-card">
                    <div class="l-bento-card-head">
                        <span class="l-bento-icon"><i class="bi bi-graph-up-arrow"></i></span>
                        <span class="l-bento-tag">Progreso</span>
                    </div>
                    <h3 class="l-bento-title">Visualiza tu evolución</h3>
                    <p class="l-bento-text">
                        Gráficos de volumen, 1RM y tendencias.
                        Que los datos hablen por ti.
                    </p>
                </div>

                <!-- Stat card -->
                <div class="l-bento-card l-bento-stat-card l-bento-stat-accent">
                    <span class="l-bento-stat-number">24/7</span>
                    <span class="l-bento-stat-label">Acceso total</span>
                </div>

                <!-- Feature wide -->
                <div class="l-bento-card l-bento-wide">
                    <div class="l-bento-card-head">
                        <span class="l-bento-icon"><i class="bi bi-rocket-takeoff"></i></span>
                        <span class="l-bento-tag">Inteligente</span>
                    </div>
                    <h3 class="l-bento-title">Sobrecarga progresiva</h3>
                    <p class="l-bento-text">
                        Métricas inteligentes para subir peso en el momento justo.
                        Crecer con cabeza, no a lo loco.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================== -->
    <!-- QUOTE + CTA -->
    <!-- ============================== -->
    <section class="l-quote-cta">
        <div class="l-container">
            <!-- Quote -->
            <div class="l-quote">
                <span class="l-quote-mark">"</span>
                <blockquote class="l-quote-text">
                    Nunca cambiarás tu vida hasta que cambies algo
                    que haces a diario. El secreto del éxito está
                    en tu rutina.
                </blockquote>
                <cite class="l-quote-author">— John C. Maxwell</cite>
            </div>

            <!-- CTA -->
            <div class="l-cta">
                @if (isLogged)
                {
                    <h2 class="l-cta-title">
                        Venga, @nombreUsuario.<br />
                        Tu PR no se va a batir solo. 🔥
                    </h2>
                    <a class="l-btn l-btn-accent l-btn-lg"
                       asp-controller="Rutinas" asp-action="CrearRutina">
                        Ir a entrenar <i class="bi bi-arrow-right"></i>
                    </a>
                }
                else
                {
                    <h2 class="l-cta-title">
                        ¿Primera vez aquí?<br />
                        Empieza gratis. Ahora.
                    </h2>
                    <p class="l-cta-sub">
                        Sin compromisos. Sin tarjeta. Solo tú y tus pesas.
                    </p>
                    <div class="l-cta-actions">
                        <a class="l-btn l-btn-accent l-btn-lg"
                           asp-controller="Usuarios" asp-action="Registro">
                            Crear cuenta <i class="bi bi-arrow-right"></i>
                        </a>
                        <a class="l-btn l-btn-ghost l-btn-lg"
                           asp-controller="Usuarios" asp-action="Login">
                            Iniciar sesión
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- ============================== -->
    <!-- FOOTER -->
    <!-- ============================== -->
    <footer class="l-footer">
        <div class="l-container l-footer-inner">
            <div class="l-footer-left">
                <a class="l-logo" asp-controller="Home" asp-action="Index">
                    SHARP<span class="l-logo-accent">GAINS</span>
                </a>
                <p class="l-footer-tagline">Tu entrenamiento. Tus datos. Tu progreso.</p>
            </div>
            <div class="l-footer-right">
                <a class="l-footer-link" asp-controller="Ejercicios" asp-action="Ejercicios">Ejercicios</a>
                <a class="l-footer-link" asp-controller="Home" asp-action="Privacy">Privacidad</a>
                @if (!isLogged)
                {
                    <a class="l-footer-link" asp-controller="Usuarios" asp-action="Registro">Crear cuenta</a>
                }
            </div>
        </div>
        <div class="l-container">
            <div class="l-footer-bottom">
                <p>&copy; 2026 SharpGains</p>
            </div>
        </div>
    </footer>

    <script>
        (function () {
            const toggle = document.getElementById('navToggle');
            const menu = document.getElementById('mobileMenu');
            const close = document.getElementById('mobileClose');
            toggle?.addEventListener('click', () => menu?.classList.add('is-open'));
            close?.addEventListener('click', () => menu?.classList.remove('is-open'));
            menu?.querySelectorAll('a').forEach(l =>
                l.addEventListener('click', () => menu.classList.remove('is-open')));
        })();
    </script>
</body>
</html>